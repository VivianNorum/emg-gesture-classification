# Python cache files, these get made automatically so no need to upload them
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter checkpoint files, these get made automatically
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environment, everyone makes their own so no need to upload it
venv/
ENV/
env/

# Editor settings, just mine, no one else needs these
.vscode/
.idea/
*.swp
*.swo
*~

# OS junk files that get made automatically, don't need these
.DS_Store
Thumbs.db

# Large dataset files (download from Kaggle)
data/raw/*.mat
data/raw/*.csv
data/raw/*.tdms
data/raw/*.npy